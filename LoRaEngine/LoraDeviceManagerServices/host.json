{
  "version": "2.0",
  "fileLoggingMode": "always",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Debug"
    },
    "console": {
      "isEnabled": true,
      "DisableColors": true
    }
  }
}